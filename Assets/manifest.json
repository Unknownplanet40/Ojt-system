{
  "name": "Internship Management System",
  "short_name": "OJTMS",
  "version": "1.1.1",
  "description": "A web-based application designed to streamline the management of internship programs, providing tools for students, supervisors, and administrators to efficiently handle tasks such as application processing, progress tracking, and communication.",
  "lang": "en-US",
  "dir": "ltr",
  "scope": "/",
  "start_url": "../",
  "notification": {
    "title": "OJTMS Notification",
    "options": {
      "body": "You have a new notification from OJTMS.",
      "icon": "Images/Icons/Icon-x192.png",
      "badge": "Images/Icons/Icon-x72.png",
      "vibrate": [
        200,
        100,
        200
      ],
      "actions": [
        {
          "action": "open",
          "title": "Open App",
          "icon": "Images/Icons/Icon-x72.png"
        },
        {
          "action": "dismiss",
          "title": "Dismiss",
          "icon": "Images/Icons/Icon-x72.png"
        }
      ]
    }
  },
  "display": "standalone",
  "background_color": "#212529",
  "theme_color": "#212529",
  "orientation": "portrait-primary",
  "display_override": [
    "window-controls-overlay"
  ],
  "author": "Ryan James Capadocia",
  "license": "MIT",
